<Window x:Class="ScrollShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SimpleScrollSC"
    Icon="{StaticResource AppIcon}"
    Height="440"
    Width="580"
    MinHeight="400"
    MinWidth="540"
    ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7F9"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Buttons: rounded with hover/pressed/disabled states -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D7DAE0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F0F2F5"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#C2C7D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E4E7EC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (accent) button -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded accent progress bar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="Background" Value="#E9ECF1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <Grid ClipToBounds="True">
                                <Border x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        CornerRadius="6"
                                        Background="{TemplateBinding Foreground}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="SimpleScrollSC"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"/>
            <TextBlock Text="Scroll-capture a window and stitch it into one tall image."
                       FontSize="12"
                       Foreground="#6B7280"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="128"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Target"
                       VerticalAlignment="Center"
                       Foreground="#374151"/>

            <Border Grid.Column="1"
                    Height="32"
                    Padding="10,0"
                    Background="White"
                    BorderBrush="#D7DAE0"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock x:Name="TargetText"
                           Text="No target selected"
                           VerticalAlignment="Center"
                           Foreground="#1F2937"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <Button Grid.Column="2"
                    x:Name="PickButton"
                    Margin="10,0,0,0"
                    Content="Pick window"
                    ToolTip="Pick a window"
                    Click="PickButton_Click"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Speed"
                       VerticalAlignment="Center"
                       Foreground="#374151"/>
            <Slider Grid.Column="1"
                    x:Name="SpeedSlider"
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="2"
                    Value="1"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    ValueChanged="SpeedSlider_ValueChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="SpeedText"
                       Text="Medium"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>

            <CheckBox Grid.Row="1"
                      Grid.Column="1"
                      Grid.ColumnSpan="2"
                      x:Name="AreaModeToggle"
                      Margin="0,10,0,0"
                      Content="Select area + click-to-start/stop"
                      Foreground="#1F2937"
                      Checked="AreaModeToggle_Changed"
                      Unchecked="AreaModeToggle_Changed"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ProgressBar"
                         Height="32"
                         VerticalAlignment="Center"
                         Minimum="0"
                         Maximum="100"
                         Value="0"/>
            <Button Grid.Column="1"
                    x:Name="CaptureButton"
                    Style="{StaticResource PrimaryButton}"
                    Margin="10,0,0,0"
                    Content="Capture"
                    Click="CaptureButton_Click"/>
        </Grid>

        <Border Grid.Row="4"
                Margin="0,16,0,0"
                Padding="10"
                Background="White"
                BorderBrush="#D7DAE0"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="82"
                        Height="74"
                        Background="#ECEFF3"
                        BorderBrush="#D7DAE0"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           Margin="2"/>
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <TextBlock x:Name="PreviewTitle"
                               Text="No capture yet"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"/>
                    <TextBlock x:Name="PreviewDetails"
                               Margin="0,4,0,0"
                               Text="Choose a target and capture."
                               Foreground="#6B7280"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Margin="0,12,0,0"
                Padding="10,6"
                Background="#111827"
                CornerRadius="6">
            <TextBlock x:Name="StatusText"
                       Text="Idle"
                       Foreground="White"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
