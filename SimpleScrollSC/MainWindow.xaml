<Window x:Class="ScrollShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SimpleScrollSC"
    Icon="{StaticResource AppIcon}"
    Height="420"
    Width="560"
    MinHeight="380"
    MinWidth="520"
    ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7F9"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
        Loaded="Window_Loaded">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SimpleScrollSC"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#1F2937"/>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="128"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Target"
                       VerticalAlignment="Center"
                       Foreground="#374151"/>

            <Border Grid.Column="1"
                    Height="30"
                    Padding="10,0"
                    Background="White"
                    BorderBrush="#D7DAE0"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock x:Name="TargetText"
                           Text="No target selected"
                           VerticalAlignment="Center"
                           Foreground="#1F2937"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <Button Grid.Column="2"
                    x:Name="PickButton"
                    Margin="10,0,0,0"
                    Height="30"
                    Content="Pick window"
                    ToolTip="Pick a window"
                    Click="PickButton_Click"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Speed"
                       VerticalAlignment="Center"
                       Foreground="#374151"/>
            <Slider Grid.Column="1"
                    x:Name="SpeedSlider"
                    Minimum="0"
                    Maximum="2"
                    Value="1"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    ValueChanged="SpeedSlider_ValueChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="SpeedText"
                       Text="Medium"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="#374151"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="112"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ProgressBar"
                         Height="28"
                         Minimum="0"
                         Maximum="100"
                         Value="0"/>
            <Button Grid.Column="1"
                    x:Name="CaptureButton"
                    Margin="10,0,0,0"
                    Content="Capture"
                    FontWeight="SemiBold"
                    Click="CaptureButton_Click"/>
        </Grid>

        <Border Grid.Row="4"
                Margin="0,14,0,0"
                Padding="8"
                Background="White"
                BorderBrush="#D7DAE0"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="82"
                        Height="74"
                        Background="#ECEFF3"
                        BorderBrush="#D7DAE0"
                        BorderThickness="1">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"/>
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <TextBlock x:Name="PreviewTitle"
                               Text="No capture yet"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"/>
                    <TextBlock x:Name="PreviewDetails"
                               Margin="0,4,0,0"
                               Text="Choose a target and capture."
                               Foreground="#6B7280"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Margin="0,12,0,0"
                Padding="8,5"
                Background="#111827"
                CornerRadius="5">
            <TextBlock x:Name="StatusText"
                       Text="Idle"
                       Foreground="White"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
